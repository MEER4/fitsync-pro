{
    "name": "api",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "postbuild": "node -e \"try { console.log('POSTBUILD DIST DIRECTORY CONTAINTS:', require('fs').readdirSync('./dist')); if (require('fs').existsSync('./dist/main.js')) { console.log('SUCCESS: main.js FOUND'); } else { console.log('CRITICAL ERROR: main.js MISSING!'); } } catch (e) { console.log('CRITICAL: FAILED TO READ DIST', e.message); }\"",
        "start": "node dist/main.js",
        "start:dev": "nest start --watch",
        "dev": "nest start --watch",
        "test": "jest"
    },
    "dependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/common": "^10.4.22",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^10.4.22",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^10.4.22",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/client": "^5.22.0",
        "@types/express": "^4.17.25",
        "@types/node": "^20.19.33",
        "@types/nodemailer": "^7.0.11",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/web-push": "^3.6.4",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "dotenv": "^16.4.7",
        "jwks-rsa": "^3.2.2",
        "nodemailer": "^8.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.1.14",
        "rxjs": "^7.8.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "web-push": "^3.6.7"
    },
    "devDependencies": {
        "@nestjs/testing": "^10.0.0",
        "@types/jest": "^29.5.14",
        "@types/supertest": "^2.0.16",
        "prisma": "^5.22.0"
    }
}
